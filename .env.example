# Root-level .env for docker-compose. Copy to .env and fill in.
# (Backend-specific defaults live in backend/.env.example for local-only dev.)

# Postgres password — used by both the db container and the backend's DATABASE_URL.
POSTGRES_PASSWORD=umbra

# Warcraft Logs API (https://www.warcraftlogs.com/api/clients)
WCL_CLIENT_ID=
WCL_CLIENT_SECRET=

# Current M+ season WCL zone ID. Midnight S1 = 47.
WCL_MPLUS_ZONE_ID=47

# Admin API key — required for POST /api/ingest and ?refresh=true.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Per-IP rate limits (slowapi syntax).
RATE_LIMIT_PUBLIC=60/minute
RATE_LIMIT_PLAYER_LOOKUP=20/minute
