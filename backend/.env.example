# Warcraft Logs API (register at https://www.warcraftlogs.com/api/clients)
WCL_CLIENT_ID=your_client_id_here
WCL_CLIENT_SECRET=your_client_secret_here
# Optional: multi-client pool. Comma-separated, paired by index. When both
# are set they override the singular pair above — queries then round-robin
# across each client's 18k-points/hr Platinum budget.
# WCL_CLIENT_IDS=id1,id2,id3
# WCL_CLIENT_SECRETS=secret1,secret2,secret3

# PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:umbra@localhost:5432/umbra

# WCL M+ Season zone ID (update each season - check warcraftlogs.com/zone/rankings)
# Midnight S1 = 47. Season manifest also lives in app/scoring/dungeons/seasons.py.
WCL_MPLUS_ZONE_ID=47

# Admin API key — required for POST /api/ingest and ?refresh=true.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave blank in dev if you don't want to protect those endpoints (they'll 503 instead).
API_KEY=

# Per-IP rate limits (slowapi syntax "<count>/<period>").
RATE_LIMIT_PUBLIC=60/minute
RATE_LIMIT_PLAYER_LOOKUP=20/minute
